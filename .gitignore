# ── Obsidian (per-machine UI state, не для общего репо) ─────────────
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
# Мусорная корзина Obsidian
.trash/

# ── git-crypt: защита от случайного коммита ключа ───────────────────
# Симметричный ключ репозитория НИКОГДА не должен попасть в git.
# (git add -f перекроет, если тебе реально нужен зашифрованный *.key)
*.key
*-git-crypt.key
git-crypt-key

# ── ОС-мусор ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# ── Редакторы / временные файлы ─────────────────────────────────────
*~
*.swp
*.swo
*.tmp
*.bak
